    "desc": {
      "en": "ioBroker adapter for Victron GX devices via local MQTT and Modbus",
      "de": "ioBroker-Adapter für Victron GX-Geräte über lokales MQTT und Modbus",
      "ru": "Адаптер ioBroker для устройств Victron GX, работающий через локальные протоколы MQTT и Modbus.",
      "pt": "Adaptador ioBroker para dispositivos Victron GX via MQTT e Modbus locais",
      "nl": "ioBroker-adapter voor Victron GX-apparaten via lokale MQTT en Modbus.",
      "fr": "Adaptateur ioBroker pour appareils Victron GX via MQTT et Modbus locaux",
      "it": "Adattatore ioBroker per dispositivi Victron GX tramite MQTT e Modbus locali.",
      "es": "Adaptador ioBroker para dispositivos Victron GX a través de MQTT y Modbus locales.",
      "pl": "Adapter ioBroker dla urządzeń Victron GX przez lokalny MQTT i Modbus",
      "uk": "Адаптер ioBroker для пристроїв Victron GX через локальний MQTT та Modbus",
      "zh-cn": "ioBroker适配器，用于通过本地MQTT和Modbus连接Victron GX设备"
    },
    "authors": [
      "Sefina-DS <ds.sefina@googlemail.com>"
    ],
    "keywords": [
      "energy",
      "victron",
      "solar",
      "mqtt",
      "modbus"
    ],
    "licenseInformation": {
      "type": "free",
      "license": "MIT"
    },
    "platform": "Javascript/Node.js",
    "icon": "victron-gx.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/Sefina-DS/ioBroker.victron-gx/main/admin/victron-gx.png",
    "readme": "https://github.com/Sefina-DS/ioBroker.victron-gx/blob/main/README.md",
    "loglevel": "info",
    "tier": 3,
    "mode": "daemon",
    "type": "energy",
    "compact": true,
    "connectionType": "local",
    "dataSource": "push",
    "adminUI": {
      "config": "json"
    },
    "jsonConfig": {
      "type": "tabs",
      "items": {
        "tabConnection": {
          "type": "tab",
          "label": "Verbindung",
          "items": {
            "host": {
              "type": "text",
              "label": "IP-Adresse des GX-Geräts",
              "help": "z.B. 192.168.1.100",
              "sm": 12,
              "md": 6
            },
            "port": {
              "type": "number",
              "label": "MQTT-Port",
              "default": 1883,
              "sm": 12,
              "md": 6
            },
            "mqttUsername": {
              "type": "text",
              "label": "MQTT-Benutzername",
              "help": "Leer lassen wenn kein Auth konfiguriert",
              "sm": 12,
              "md": 6
            },
            "mqttPassword": {
              "type": "password",
              "label": "MQTT-Passwort",
              "sm": 12,
              "md": 6
            }
          }
        },
        "tabControl": {
          "type": "tab",
          "label": "Steuerung",
          "items": {
            "controlEnabled": {
              "type": "checkbox",
              "label": "Steuerung aktivieren (Modbus TCP)",
              "default": false,
              "sm": 12
            },
            "modbusHint": {
              "type": "staticText",
              "text": "⚠️ Voraussetzung am GX-Gerät:\n1. Einstellungen → Integrationen → Modbus TCP-Server → Aktiviert\n2. Zugriffsberechtigungen → Schreiben erlaubt\n\nVirtuelle Schalter werden weiterhin über MQTT gesteuert.\nAlle anderen Geräte (MultiPlus, Batterie, etc.) werden über Modbus TCP gesteuert.\nDie Modbus Unit IDs werden automatisch vom GX ermittelt und unter info.modbusId gespeichert.",
              "sm": 12
            },
            "modbusPort": {
              "type": "number",
              "label": "Modbus Port",
              "default": 502,
              "sm": 12,
              "md": 4,
              "visibleIf": "controlEnabled",
              "visibleIfValue": true
            }
          }
        }
      }
    },
    "dependencies": [
      {
        "js-controller": ">=6.0.11"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.0.23"
      }
    ],
    "installedFrom": "/opt/iobroker/dev/ioBroker.victron-gx"
  },
  "native": {
    "host": "192.168.1.x",
    "port": 1883,
    "mqttUsername": "",
    "mqttPassword": "",
    "controlEnabled": false,
    "modbusPort": 502,
    "pollingInterval": 5000
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "indicator.connected",
        "name": "Device or service connected",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}